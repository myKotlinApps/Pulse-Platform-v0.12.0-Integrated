<?xml version="1.0" encoding="utf-8"?><ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true"><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
<TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="اتصال ELM327" android:textColor="@color/text" android:textStyle="bold" android:textSize="22sp"/>
<TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="تم رابط و المان‌های EPS" android:textColor="@color/muted"/>
<Spinner android:id="@+id/themeSpinner" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="6dp" android:background="@drawable/bg_input"/>
<TextView android:id="@+id/themeDescription" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="تم انتخابی روی داشبورد و رنگ‌های اصلی برنامه اعمال می‌شود." android:textColor="@color/muted" android:textSize="11sp"/>
<RadioGroup android:id="@+id/transportGroup" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal">
<RadioButton android:id="@+id/bluetoothRadio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" android:text="Bluetooth Classic" android:textColor="@color/text"/>
<RadioButton android:id="@+id/wifiRadio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Wi‑Fi TCP" android:textColor="@color/text"/>
<RadioButton android:id="@+id/mockRadio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Demo" android:textColor="@color/text"/>
</RadioGroup>
<TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="دستگاه‌های Pair شده" android:textColor="@color/muted"/>
<Spinner android:id="@+id/bluetoothDeviceSpinner" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/bg_input"/>
<EditText android:id="@+id/wifiHost" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="8dp" android:background="@drawable/bg_input" android:hint="IP ماژول؛ 192.168.0.10" android:inputType="textUri" android:paddingLeft="12dp" android:paddingRight="12dp" android:text="192.168.0.10" android:textColor="@color/text" android:textColorHint="@color/muted"/>
<EditText android:id="@+id/wifiPort" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="8dp" android:background="@drawable/bg_input" android:hint="Port؛ معمولاً 35000" android:inputType="number" android:paddingLeft="12dp" android:paddingRight="12dp" android:text="35000" android:textColor="@color/text" android:textColorHint="@color/muted"/>
<CheckBox android:id="@+id/backgroundCheck" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="اتصال در پس‌زمینه حفظ شود (مصرف باتری بیشتر)" android:textColor="@color/text"/>
<Button android:id="@+id/connectButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="اتصال"/>
<Button android:id="@+id/disconnectButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="قطع اتصال"/>
<TextView android:id="@+id/adapterLog" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/bg_card" android:fontFamily="monospace" android:text="آماده" android:textColor="@color/muted" android:textDirection="ltr"/>
</LinearLayout></ScrollView>