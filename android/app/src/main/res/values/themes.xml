<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ECUPulse" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:fontFamily">sans</item><item name="fontFamily">sans</item>
        <item name="android:windowLightStatusBar">false</item><item name="android:navigationBarColor">@color/bg</item>
        <item name="android:statusBarColor">@color/bg</item><item name="colorPrimary">@color/cyan</item>
        <item name="colorSecondary">@color/green</item><item name="android:windowBackground">@color/bg</item>
    </style>
    <style name="ProFeatureCard">
        <item name="android:layout_width">match_parent</item><item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item><item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">16dp</item><item name="android:textColor">@color/text</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="ProFeatureButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">match_parent</item><item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item><item name="android:minHeight">56dp</item>
        <item name="android:textColor">@color/text</item><item name="android:gravity">center_vertical|start</item>
    </style>

    <style name="MyDiagMenuButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">128dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:background">@drawable/bg_mydiag_menu</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/mydiag_text</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">13sp</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
